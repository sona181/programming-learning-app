// =============================================================================
// Prisma Schema — Gamified Programming Learning Platform
// Database: PostgreSQL
// ORM: Prisma
// =============================================================================
// PROTECTED TABLES (already exist — do not migrate):
//   users, user_profiles, user_settings, notifications,
//   instructor_profiles, course_categories, courses
// NEW TABLES: everything else below
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// MODULE A — CORE / AUTH / PROFILE
// =============================================================================

// PROTECTED — already exists
model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         String    @db.VarChar(20)
  isActive     Boolean   @map("is_active")
  isVerified   Boolean   @map("is_verified")
  createdAt    DateTime  @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  profile                UserProfile?
  settings               UserSettings?
  notifications          Notification[]
  instructorProfile      InstructorProfile?
  courses                Course[]
  courseAuthors          CourseAuthor[]
  enrollments            Enrollment[]
  certificates           Certificate[]
  quizAttempts           QuizAttempt[]
  onboardingResponses    OnboardingResponse[]
  placementAttempts      PlacementAttempt[]
  pathEnrollments        UserPathEnrollment[]
  dailyPlans             DailyPlan[]
  reviewQueueItems       ReviewQueueItem[]
  energy                 UserEnergy?
  energyTransactions     EnergyTransaction[]
  streak                 UserStreak?
  xpLogs                 XpLog[]
  userBadges             UserBadge[]
  userAchievements       UserAchievement[]
  sessionBookingsStudent SessionBooking[]     @relation("StudentBookings")
  sessionNotes           SessionNote[]
  subscriptions          UserSubscription[]
  payments               Payment[]

  @@map("users")
}

// PROTECTED — already exists
model UserProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  displayName String   @map("display_name") @db.VarChar(100)
  avatarUrl   String?  @map("avatar_url") @db.VarChar(500)
  bio         String?  @db.Text
  country     String?  @db.VarChar(100)
  timezone    String?  @db.VarChar(100)
  createdAt   DateTime @map("created_at") @db.Timestamptz
  updatedAt   DateTime @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

// PROTECTED — already exists
model UserSettings {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @map("user_id") @db.Uuid
  emailNotifications Boolean  @map("email_notifications")
  language           String   @db.VarChar(10)
  darkMode           Boolean  @map("dark_mode")
  updatedAt          DateTime @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("user_settings")
}

// PROTECTED — already exists
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  message   String   @db.Text
  isRead    Boolean  @map("is_read")
  createdAt DateTime @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

// PROTECTED — already exists
model InstructorProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  bio         String?  @db.Text
  specialties String?  @db.VarChar(255)
  languages   String?  @db.VarChar(255)
  hourlyRate  Decimal? @map("hourly_rate") @db.Decimal(10, 2)
  rating      Decimal? @db.Decimal(3, 2)
  isVerified  Boolean  @map("is_verified")
  isAvailable Boolean  @map("is_available")
  createdAt   DateTime @map("created_at") @db.Timestamptz
  updatedAt   DateTime @map("updated_at") @db.Timestamptz

  user              User               @relation(fields: [userId], references: [id])
  availabilitySlots AvailabilitySlot[]
  sessionBookings   SessionBooking[]   @relation("InstructorBookings")

  @@map("instructor_profiles")
}

// =============================================================================
// MODULE B — COURSE LIBRARY
// =============================================================================

// PROTECTED — already exists
model CourseCategory {
  id       String  @id @default(uuid()) @db.Uuid
  name     String  @unique @db.VarChar(100)
  slug     String  @unique @db.VarChar(120)
  parentId String? @map("parent_id") @db.Uuid

  parent   CourseCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children CourseCategory[] @relation("CategoryHierarchy")
  courses  Course[]

  @@map("course_categories")
}

// PROTECTED — already exists
model Course {
  id           String    @id @default(uuid()) @db.Uuid
  categoryId   String?   @map("category_id") @db.Uuid
  authorId     String    @map("author_id") @db.Uuid
  title        String    @db.VarChar(255)
  description  String?   @db.Text
  slug         String    @unique @db.VarChar(300)
  level        String    @db.VarChar(20)
  status       String    @db.VarChar(20)
  isPremium    Boolean   @map("is_premium")
  price        Decimal?  @db.Decimal(10, 2)
  thumbnailUrl String?   @map("thumbnail_url") @db.VarChar(500)
  language     String    @db.VarChar(10)
  publishedAt  DateTime? @map("published_at") @db.Timestamptz
  createdAt    DateTime  @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @map("updated_at") @db.Timestamptz

  category      CourseCategory? @relation(fields: [categoryId], references: [id])
  author        User            @relation(fields: [authorId], references: [id])
  courseAuthors CourseAuthor[]
  chapters      Chapter[]
  enrollments   Enrollment[]
  certificates  Certificate[]
  payments      Payment[]

  @@index([categoryId])
  @@index([authorId])
  @@map("courses")
}

// NEW
model CourseAuthor {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  authorRole String   @map("author_role") @db.VarChar(20)
  addedAt    DateTime @map("added_at") @db.Timestamptz

  course Course @relation(fields: [courseId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@map("course_authors")
}

// NEW
model Chapter {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  title      String   @db.VarChar(255)
  orderIndex Int      @map("order_index")
  createdAt  DateTime @map("created_at") @db.Timestamptz

  course  Course   @relation(fields: [courseId], references: [id])
  lessons Lesson[]
  quizzes Quiz[]

  @@index([courseId])
  @@map("chapters")
}

// NEW
model Lesson {
  id              String   @id @default(uuid()) @db.Uuid
  chapterId       String   @map("chapter_id") @db.Uuid
  title           String   @db.VarChar(255)
  lessonType      String   @map("lesson_type") @db.VarChar(50)
  orderIndex      Int      @map("order_index")
  durationSeconds Int?     @map("duration_seconds")
  isFreePreview   Boolean  @map("is_free_preview")
  createdAt       DateTime @map("created_at") @db.Timestamptz

  chapter        Chapter          @relation(fields: [chapterId], references: [id])
  lessonContents LessonContent[]
  lessonProgress LessonProgress[]

  @@index([chapterId])
  @@map("lessons")
}

// NEW
model LessonContent {
  id          String   @id @default(uuid()) @db.Uuid
  lessonId    String   @map("lesson_id") @db.Uuid
  contentType String   @map("content_type") @db.VarChar(50)
  body        String?  @db.Text
  mediaUrl    String?  @map("media_url") @db.VarChar(1000)
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @map("created_at") @db.Timestamptz

  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@index([lessonId])
  @@map("lesson_contents")
}

// NEW
model Enrollment {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  courseId    String    @map("course_id") @db.Uuid
  status      String    @db.VarChar(20)
  enrolledAt  DateTime  @map("enrolled_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz

  user           User             @relation(fields: [userId], references: [id])
  course         Course           @relation(fields: [courseId], references: [id])
  lessonProgress LessonProgress[]
  courseProgress CourseProgress?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

// NEW
model LessonProgress {
  id           String    @id @default(uuid()) @db.Uuid
  enrollmentId String    @map("enrollment_id") @db.Uuid
  lessonId     String    @map("lesson_id") @db.Uuid
  isCompleted  Boolean   @map("is_completed")
  completedAt  DateTime? @map("completed_at") @db.Timestamptz

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  lesson     Lesson     @relation(fields: [lessonId], references: [id])

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
  @@map("lesson_progress")
}

// NEW
model CourseProgress {
  id               String    @id @default(uuid()) @db.Uuid
  enrollmentId     String    @unique @map("enrollment_id") @db.Uuid
  totalLessons     Int       @map("total_lessons")
  completedLessons Int       @map("completed_lessons")
  progressPercent  Decimal   @map("progress_percent") @db.Decimal(5, 2)
  lastAccessedAt   DateTime? @map("last_accessed_at") @db.Timestamptz
  updatedAt        DateTime  @map("updated_at") @db.Timestamptz

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@map("course_progress")
}

// NEW
model Certificate {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  courseId          String?  @map("course_id") @db.Uuid
  pathId            String?  @map("path_id") @db.Uuid
  certificateNumber String   @unique @map("certificate_number") @db.VarChar(100)
  type              String   @db.VarChar(20)
  issuedAt          DateTime @map("issued_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id])
  course       Course?       @relation(fields: [courseId], references: [id])
  learningPath LearningPath? @relation(fields: [pathId], references: [id])

  @@index([userId])
  @@map("certificates")
}

// =============================================================================
// MODULE C — QUIZ / ASSESSMENT
// =============================================================================

// NEW
// XOR constraint (chapter_id OR path_unit_id, not both) is enforced at
// application layer. Both columns are nullable in the DB.
model Quiz {
  id               String   @id @default(uuid()) @db.Uuid
  chapterId        String?  @map("chapter_id") @db.Uuid
  pathUnitId       String?  @map("path_unit_id") @db.Uuid
  title            String   @db.VarChar(255)
  passScore        Int      @map("pass_score")
  timeLimitSeconds Int?     @map("time_limit_seconds")
  createdAt        DateTime @map("created_at") @db.Timestamptz

  chapter   Chapter?      @relation(fields: [chapterId], references: [id])
  pathUnit  PathUnit?     @relation(fields: [pathUnitId], references: [id])
  questions Question[]
  attempts  QuizAttempt[]

  @@index([chapterId])
  @@index([pathUnitId])
  @@map("quizzes")
}

// NEW
model Question {
  id           String @id @default(uuid()) @db.Uuid
  quizId       String @map("quiz_id") @db.Uuid
  body         String @db.Text
  questionType String @map("question_type") @db.VarChar(50)
  orderIndex   Int    @map("order_index")
  points       Int

  quiz               Quiz                @relation(fields: [quizId], references: [id])
  answerOptions      AnswerOption[]
  quizAttemptAnswers QuizAttemptAnswer[]
  placementAnswers   PlacementAnswer[]

  @@index([quizId])
  @@map("questions")
}

// NEW
model AnswerOption {
  id         String  @id @default(uuid()) @db.Uuid
  questionId String  @map("question_id") @db.Uuid
  body       String  @db.Text
  isCorrect  Boolean @map("is_correct")
  orderIndex Int     @map("order_index")

  question           Question            @relation(fields: [questionId], references: [id])
  quizAttemptAnswers QuizAttemptAnswer[]
  placementAnswers   PlacementAnswer[]

  @@index([questionId])
  @@map("answer_options")
}

// NEW
model QuizAttempt {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  quizId           String   @map("quiz_id") @db.Uuid
  score            Int
  maxScore         Int      @map("max_score")
  passed           Boolean
  timeTakenSeconds Int?     @map("time_taken_seconds")
  attemptedAt      DateTime @map("attempted_at") @db.Timestamptz

  user    User                @relation(fields: [userId], references: [id])
  quiz    Quiz                @relation(fields: [quizId], references: [id])
  answers QuizAttemptAnswer[]

  @@index([userId])
  @@index([quizId])
  @@map("quiz_attempts")
}

// NEW
model QuizAttemptAnswer {
  id               String  @id @default(uuid()) @db.Uuid
  attemptId        String  @map("attempt_id") @db.Uuid
  questionId       String  @map("question_id") @db.Uuid
  selectedOptionId String? @map("selected_option_id") @db.Uuid
  isCorrect        Boolean @map("is_correct")

  attempt        QuizAttempt   @relation(fields: [attemptId], references: [id])
  question       Question      @relation(fields: [questionId], references: [id])
  selectedOption AnswerOption? @relation(fields: [selectedOptionId], references: [id])

  @@index([attemptId])
  @@map("quiz_attempt_answers")
}

// =============================================================================
// MODULE D — ACADEMY / GUIDED PATH
// =============================================================================

// NEW
model LearningPath {
  id            String   @id @default(uuid()) @db.Uuid
  title         String   @db.VarChar(255)
  slug          String   @unique @db.VarChar(300)
  description   String?  @db.Text
  level         String   @db.VarChar(20)
  language      String   @db.VarChar(10)
  status        String   @db.VarChar(20)
  estimatedDays Int?     @map("estimated_days")
  createdAt     DateTime @map("created_at") @db.Timestamptz
  updatedAt     DateTime @map("updated_at") @db.Timestamptz

  pathUnits         PathUnit[]
  placementAttempts PlacementAttempt[]
  userEnrollments   UserPathEnrollment[]
  certificates      Certificate[]

  @@map("learning_paths")
}

// NEW
model PathUnit {
  id          String   @id @default(uuid()) @db.Uuid
  pathId      String   @map("path_id") @db.Uuid
  title       String   @db.VarChar(255)
  description String?  @db.Text
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @map("created_at") @db.Timestamptz

  learningPath LearningPath @relation(fields: [pathId], references: [id])
  pathLessons  PathLesson[]
  quizzes      Quiz[]

  @@index([pathId])
  @@map("path_units")
}

// NEW
model PathLesson {
  id         String   @id @default(uuid()) @db.Uuid
  unitId     String   @map("unit_id") @db.Uuid
  title      String   @db.VarChar(255)
  orderIndex Int      @map("order_index")
  xpReward   Int      @map("xp_reward")
  createdAt  DateTime @map("created_at") @db.Timestamptz

  pathUnit         PathUnit           @relation(fields: [unitId], references: [id])
  pathActivities   PathActivity[]
  userPathProgress UserPathProgress[]

  @@index([unitId])
  @@map("path_lessons")
}

// NEW
model PathActivity {
  id            String  @id @default(uuid()) @db.Uuid
  pathLessonId  String  @map("path_lesson_id") @db.Uuid
  activityType  String  @map("activity_type") @db.VarChar(50)
  prompt        String  @db.Text
  correctAnswer String? @map("correct_answer") @db.Text
  options       Json?
  orderIndex    Int     @map("order_index")
  xpReward      Int     @map("xp_reward")

  pathLesson       PathLesson        @relation(fields: [pathLessonId], references: [id])
  dailyPlanItems   DailyPlanItem[]
  reviewQueueItems ReviewQueueItem[]

  @@index([pathLessonId])
  @@map("path_activities")
}

// NEW
model OnboardingResponse {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  questionKey String   @map("question_key") @db.VarChar(100)
  answerValue String   @map("answer_value") @db.VarChar(255)
  respondedAt DateTime @map("responded_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("onboarding_responses")
}

// NEW
model PlacementAttempt {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  pathId        String   @map("path_id") @db.Uuid
  score         Int?
  assignedLevel String?  @map("assigned_level") @db.VarChar(20)
  attemptedAt   DateTime @map("attempted_at") @db.Timestamptz

  user             User              @relation(fields: [userId], references: [id])
  learningPath     LearningPath      @relation(fields: [pathId], references: [id])
  placementAnswers PlacementAnswer[]

  @@index([userId])
  @@index([pathId])
  @@map("placement_attempts")
}

// NEW
model PlacementAnswer {
  id                 String  @id @default(uuid()) @db.Uuid
  placementAttemptId String  @map("placement_attempt_id") @db.Uuid
  questionId         String  @map("question_id") @db.Uuid
  selectedOptionId   String? @map("selected_option_id") @db.Uuid
  isCorrect          Boolean @map("is_correct")

  placementAttempt PlacementAttempt @relation(fields: [placementAttemptId], references: [id])
  question         Question         @relation(fields: [questionId], references: [id])
  selectedOption   AnswerOption?    @relation(fields: [selectedOptionId], references: [id])

  @@index([placementAttemptId])
  @@map("placement_answers")
}

// NEW
model UserPathEnrollment {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  pathId      String    @map("path_id") @db.Uuid
  level       String    @db.VarChar(20)
  status      String    @db.VarChar(20)
  isActive    Boolean   @map("is_active")
  enrolledAt  DateTime  @map("enrolled_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz

  user             User               @relation(fields: [userId], references: [id])
  learningPath     LearningPath       @relation(fields: [pathId], references: [id])
  userPathProgress UserPathProgress[]
  dailyPlans       DailyPlan[]

  @@unique([userId, pathId])
  @@index([userId])
  @@index([pathId])
  @@map("user_path_enrollments")
}

// NEW
model UserPathProgress {
  id           String    @id @default(uuid()) @db.Uuid
  enrollmentId String    @map("enrollment_id") @db.Uuid
  pathLessonId String    @map("path_lesson_id") @db.Uuid
  isCompleted  Boolean   @map("is_completed")
  xpEarned     Int       @map("xp_earned")
  completedAt  DateTime? @map("completed_at") @db.Timestamptz

  enrollment UserPathEnrollment @relation(fields: [enrollmentId], references: [id])
  pathLesson PathLesson         @relation(fields: [pathLessonId], references: [id])

  @@unique([enrollmentId, pathLessonId])
  @@index([enrollmentId])
  @@map("user_path_progress")
}

// NEW
model ReviewQueueItem {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  pathActivityId   String    @map("path_activity_id") @db.Uuid
  intervalDays     Int       @map("interval_days")
  repetitionCount  Int       @map("repetition_count")
  easeFactor       Decimal   @map("ease_factor") @db.Decimal(4, 2)
  nextReviewDate   DateTime  @map("next_review_date") @db.Date
  lastReviewedDate DateTime? @map("last_reviewed_date") @db.Date

  user           User            @relation(fields: [userId], references: [id])
  pathActivity   PathActivity    @relation(fields: [pathActivityId], references: [id])
  dailyPlanItems DailyPlanItem[]

  @@index([userId])
  @@index([nextReviewDate])
  @@map("review_queue_items")
}

// NEW
model DailyPlan {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  enrollmentId String   @map("enrollment_id") @db.Uuid
  planDate     DateTime @map("plan_date") @db.Date
  isCompleted  Boolean  @map("is_completed")
  generatedAt  DateTime @map("generated_at") @db.Timestamptz

  user       User               @relation(fields: [userId], references: [id])
  enrollment UserPathEnrollment @relation(fields: [enrollmentId], references: [id])
  items      DailyPlanItem[]

  @@unique([userId, planDate])
  @@index([userId])
  @@map("daily_plans")
}

// NEW
// item_type determines which FK is set: "activity" → path_activity_id,
// "review" → review_item_id. Application enforces the XOR.
model DailyPlanItem {
  id             String  @id @default(uuid()) @db.Uuid
  dailyPlanId    String  @map("daily_plan_id") @db.Uuid
  pathActivityId String? @map("path_activity_id") @db.Uuid
  reviewItemId   String? @map("review_item_id") @db.Uuid
  itemType       String  @map("item_type") @db.VarChar(50)
  isCompleted    Boolean @map("is_completed")
  orderIndex     Int     @map("order_index")

  dailyPlan       DailyPlan        @relation(fields: [dailyPlanId], references: [id])
  pathActivity    PathActivity?    @relation(fields: [pathActivityId], references: [id])
  reviewQueueItem ReviewQueueItem? @relation(fields: [reviewItemId], references: [id])

  @@index([dailyPlanId])
  @@map("daily_plan_items")
}

// =============================================================================
// MODULE E — GAMIFICATION
// =============================================================================

// NEW
model UserEnergy {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  currentEnergy Int      @map("current_energy")
  maxEnergy     Int      @map("max_energy")
  lastRefillAt  DateTime @map("last_refill_at") @db.Timestamptz
  updatedAt     DateTime @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("user_energy")
}

// NEW
model EnergyTransaction {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  delta     Int
  reason    String   @db.VarChar(100)
  createdAt DateTime @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("energy_transactions")
}

// NEW
model UserStreak {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  currentStreak    Int      @map("current_streak")
  longestStreak    Int      @map("longest_streak")
  lastActivityDate DateTime @map("last_activity_date") @db.Date
  updatedAt        DateTime @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("user_streaks")
}

// NEW
model XpLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  xpAmount    Int      @map("xp_amount")
  sourceType  String   @map("source_type") @db.VarChar(50)
  sourceId    String?  @map("source_id") @db.Uuid
  description String?  @db.Text
  earnedAt    DateTime @map("earned_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("xp_logs")
}

// NEW
model Badge {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @unique @db.VarChar(100)
  slug          String   @unique @db.VarChar(120)
  description   String?  @db.Text
  iconUrl       String?  @map("icon_url") @db.VarChar(500)
  criteriaType  String   @map("criteria_type") @db.VarChar(50)
  criteriaValue Int      @map("criteria_value")
  createdAt     DateTime @map("created_at") @db.Timestamptz

  userBadges UserBadge[]

  @@map("badges")
}

// NEW
model UserBadge {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  badgeId  String   @map("badge_id") @db.Uuid
  earnedAt DateTime @map("earned_at") @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// NEW
model Achievement {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @unique @db.VarChar(100)
  slug          String   @unique @db.VarChar(120)
  description   String?  @db.Text
  iconUrl       String?  @map("icon_url") @db.VarChar(500)
  criteriaType  String   @map("criteria_type") @db.VarChar(50)
  criteriaValue Int      @map("criteria_value")
  createdAt     DateTime @map("created_at") @db.Timestamptz

  userAchievements UserAchievement[]

  @@map("achievements")
}

// NEW
model UserAchievement {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  achievementId String    @map("achievement_id") @db.Uuid
  currentValue  Int       @map("current_value")
  isCompleted   Boolean   @map("is_completed")
  completedAt   DateTime? @map("completed_at") @db.Timestamptz

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// =============================================================================
// MODULE F — LIVE TEACHING
// =============================================================================

// NEW
model AvailabilitySlot {
  id           String   @id @default(uuid()) @db.Uuid
  instructorId String   @map("instructor_id") @db.Uuid
  startsAt     DateTime @map("starts_at") @db.Timestamptz
  endsAt       DateTime @map("ends_at") @db.Timestamptz
  isBooked     Boolean  @map("is_booked")
  createdAt    DateTime @map("created_at") @db.Timestamptz

  instructorProfile InstructorProfile @relation(fields: [instructorId], references: [id])
  sessionBookings   SessionBooking[]

  @@index([instructorId])
  @@index([startsAt])
  @@map("availability_slots")
}

// NEW
model SessionBooking {
  id           String    @id @default(uuid()) @db.Uuid
  studentId    String    @map("student_id") @db.Uuid
  instructorId String    @map("instructor_id") @db.Uuid
  slotId       String    @map("slot_id") @db.Uuid
  topic        String?   @db.VarChar(255)
  status       String    @db.VarChar(20)
  amountPaid   Decimal?  @map("amount_paid") @db.Decimal(10, 2)
  bookedAt     DateTime  @map("booked_at") @db.Timestamptz
  cancelledAt  DateTime? @map("cancelled_at") @db.Timestamptz

  student           User              @relation("StudentBookings", fields: [studentId], references: [id])
  instructorProfile InstructorProfile @relation("InstructorBookings", fields: [instructorId], references: [id])
  slot              AvailabilitySlot  @relation(fields: [slotId], references: [id])
  liveSession       LiveSession?
  payments          Payment[]

  @@index([studentId])
  @@index([instructorId])
  @@map("session_bookings")
}

// NEW
model LiveSession {
  id                String    @id @default(uuid()) @db.Uuid
  bookingId         String    @unique @map("booking_id") @db.Uuid
  externalMeetingId String?   @map("external_meeting_id") @db.VarChar(255)
  joinUrl           String?   @map("join_url") @db.VarChar(500)
  provider          String?   @db.VarChar(50)
  status            String    @db.VarChar(20)
  durationMinutes   Int?      @map("duration_minutes")
  startedAt         DateTime? @map("started_at") @db.Timestamptz
  endedAt           DateTime? @map("ended_at") @db.Timestamptz

  booking      SessionBooking @relation(fields: [bookingId], references: [id])
  sessionNotes SessionNote[]

  @@map("live_sessions")
}

// NEW
model SessionNote {
  id                  String   @id @default(uuid()) @db.Uuid
  sessionId           String   @map("session_id") @db.Uuid
  authorId            String   @map("author_id") @db.Uuid
  content             String   @db.Text
  isSharedWithStudent Boolean  @map("is_shared_with_student")
  createdAt           DateTime @map("created_at") @db.Timestamptz
  updatedAt           DateTime @map("updated_at") @db.Timestamptz

  session LiveSession @relation(fields: [sessionId], references: [id])
  author  User        @relation(fields: [authorId], references: [id])

  @@index([sessionId])
  @@map("session_notes")
}

// =============================================================================
// MODULE G — PRICING / MONETIZATION
// =============================================================================

// NEW
model PricingPlan {
  id                      String   @id @default(uuid()) @db.Uuid
  name                    String   @unique @db.VarChar(100)
  slug                    String   @unique @db.VarChar(120)
  description             String?  @db.Text
  priceMonthly            Decimal  @map("price_monthly") @db.Decimal(10, 2)
  priceYearly             Decimal? @map("price_yearly") @db.Decimal(10, 2)
  hasPremiumCourses       Boolean  @map("has_premium_courses")
  hasLiveSessions         Boolean  @map("has_live_sessions")
  hasAcademy              Boolean  @map("has_academy")
  maxLiveSessionsPerMonth Int?     @map("max_live_sessions_per_month")
  isActive                Boolean  @map("is_active")
  createdAt               DateTime @map("created_at") @db.Timestamptz

  subscriptions UserSubscription[]

  @@map("pricing_plans")
}

// NEW
model UserSubscription {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  planId       String    @map("plan_id") @db.Uuid
  status       String    @db.VarChar(20)
  billingCycle String    @map("billing_cycle") @db.VarChar(10)
  startedAt    DateTime  @map("started_at") @db.Timestamptz
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  cancelledAt  DateTime? @map("cancelled_at") @db.Timestamptz

  user     User        @relation(fields: [userId], references: [id])
  plan     PricingPlan @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@map("user_subscriptions")
}

// NEW
// Exactly one of subscription_id, course_id, booking_id should be non-null
// per payment. This XOR is enforced at the application layer.
model Payment {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  subscriptionId    String?   @map("subscription_id") @db.Uuid
  courseId          String?   @map("course_id") @db.Uuid
  bookingId         String?   @map("booking_id") @db.Uuid
  amount            Decimal   @db.Decimal(10, 2)
  currency          String    @db.VarChar(10)
  status            String    @db.VarChar(20)
  provider          String?   @db.VarChar(50)
  providerReference String?   @map("provider_reference") @db.VarChar(255)
  paidAt            DateTime? @map("paid_at") @db.Timestamptz
  createdAt         DateTime  @map("created_at") @db.Timestamptz

  user         User              @relation(fields: [userId], references: [id])
  subscription UserSubscription? @relation(fields: [subscriptionId], references: [id])
  course       Course?           @relation(fields: [courseId], references: [id])
  booking      SessionBooking?   @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("payments")
}
