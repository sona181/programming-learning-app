generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String               @id @default(uuid()) @db.Uuid
  email                  String               @unique @db.VarChar(255)
  passwordHash           String               @map("password_hash") @db.VarChar(255)
  role                   String               @db.VarChar(20)
  isActive               Boolean              @map("is_active")
  isVerified             Boolean              @map("is_verified")
  createdAt              DateTime             @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime             @map("updated_at") @db.Timestamptz(6)
  deletedAt              DateTime?            @map("deleted_at") @db.Timestamptz(6)
  certificates           Certificate[]
  courseAuthors          CourseAuthor[]
  courses                Course[]
  dailyPlans             DailyPlan[]
  energyTransactions     EnergyTransaction[]
  enrollments            Enrollment[]
  instructorProfile      InstructorProfile?
  notifications          Notification[]
  onboardingResponses    OnboardingResponse[]
  payments               Payment[]
  placementAttempts      PlacementAttempt[]
  quizAttempts           QuizAttempt[]
  courseReviews          CourseReview[]
  reviewQueueItems       ReviewQueueItem[]
  sessionBookingsStudent SessionBooking[]     @relation("StudentBookings")
  sessionNotes           SessionNote[]
  userAchievements       UserAchievement[]
  userBadges             UserBadge[]
  energy                 UserEnergy?
  pathEnrollments        UserPathEnrollment[]
  profile                UserProfile?
  settings               UserSettings?
  streak                 UserStreak?
  subscriptions          UserSubscription[]
  xpLogs                 XpLog[]

  @@map("users")
}

model UserProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  displayName String   @map("display_name") @db.VarChar(100)
  avatarUrl   String?  @map("avatar_url") @db.VarChar(500)
  bio         String?
  country     String?  @db.VarChar(100)
  timezone    String?  @db.VarChar(100)
  createdAt   DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @map("updated_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

model UserSettings {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @map("user_id") @db.Uuid
  emailNotifications Boolean  @map("email_notifications")
  language           String   @db.VarChar(10)
  darkMode           Boolean  @map("dark_mode")
  updatedAt          DateTime @map("updated_at") @db.Timestamptz(6)
  user               User     @relation(fields: [userId], references: [id])

  @@map("user_settings")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  message   String
  isRead    Boolean  @map("is_read")
  createdAt DateTime @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

model InstructorProfile {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String             @unique @map("user_id") @db.Uuid
  bio               String?
  specialties       String?            @db.VarChar(255)
  languages         String?            @db.VarChar(255)
  hourlyRate        Decimal?           @map("hourly_rate") @db.Decimal(10, 2)
  rating            Decimal?           @db.Decimal(3, 2)
  isVerified        Boolean            @map("is_verified")
  isAvailable       Boolean            @map("is_available")
  createdAt         DateTime           @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @map("updated_at") @db.Timestamptz(6)
  availabilitySlots AvailabilitySlot[]
  user              User               @relation(fields: [userId], references: [id])
  sessionBookings   SessionBooking[]   @relation("InstructorBookings")

  @@map("instructor_profiles")
}

model CourseCategory {
  id       String           @id @default(uuid()) @db.Uuid
  name     String           @unique @db.VarChar(100)
  slug     String           @unique @db.VarChar(120)
  parentId String?          @map("parent_id") @db.Uuid
  parent   CourseCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children CourseCategory[] @relation("CategoryHierarchy")
  courses  Course[]

  @@map("course_categories")
}

model Course {
  id            String          @id @default(uuid()) @db.Uuid
  categoryId    String?         @map("category_id") @db.Uuid
  authorId      String          @map("author_id") @db.Uuid
  title         String          @db.VarChar(255)
  description   String?
  slug          String          @unique @db.VarChar(300)
  level         String          @db.VarChar(20)
  status        String          @db.VarChar(20)
  isPremium     Boolean         @map("is_premium")
  price         Decimal?        @db.Decimal(10, 2)
  thumbnailUrl  String?         @map("thumbnail_url") @db.VarChar(500)
  language      String          @db.VarChar(10)
  publishedAt   DateTime?       @map("published_at") @db.Timestamptz(6)
  createdAt     DateTime        @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @map("updated_at") @db.Timestamptz(6)
  certificates  Certificate[]
  chapters      Chapter[]
  courseAuthors CourseAuthor[]
  assets        CourseAsset[]
  landingPage   CourseLandingPage?
  author        User            @relation(fields: [authorId], references: [id])
  category      CourseCategory? @relation(fields: [categoryId], references: [id])
  enrollments   Enrollment[]
  payments      Payment[]
  reviews       CourseReview[]

  @@index([categoryId])
  @@index([authorId])
  @@map("courses")
}

model CourseReview {
  id        String   @id @default(uuid()) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @map("updated_at") @db.Timestamptz(6)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@map("course_reviews")
}

model CourseAuthor {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  authorRole String   @map("author_role") @db.VarChar(20)
  addedAt    DateTime @map("added_at") @db.Timestamptz(6)
  course     Course   @relation(fields: [courseId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@map("course_authors")
}

model Chapter {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  title      String   @db.VarChar(255)
  orderIndex Int      @map("order_index")
  createdAt  DateTime @map("created_at") @db.Timestamptz(6)
  course     Course   @relation(fields: [courseId], references: [id])
  lessons    Lesson[]
  quizzes    Quiz[]

  @@index([courseId])
  @@map("chapters")
}

model Lesson {
  id              String           @id @default(uuid()) @db.Uuid
  chapterId       String           @map("chapter_id") @db.Uuid
  title           String           @db.VarChar(255)
  lessonType      String           @map("lesson_type") @db.VarChar(50)
  orderIndex      Int              @map("order_index")
  durationSeconds Int?             @map("duration_seconds")
  isFreePreview   Boolean          @map("is_free_preview")
  createdAt       DateTime         @map("created_at") @db.Timestamptz(6)
  lessonContents  LessonContent[]
  lessonProgress  LessonProgress[]
  exercises       CourseExercise[]
  assets          CourseAsset[]
  chapter         Chapter          @relation(fields: [chapterId], references: [id])

  @@index([chapterId])
  @@map("lessons")
}

model LessonContent {
  id          String   @id @default(uuid()) @db.Uuid
  lessonId    String   @map("lesson_id") @db.Uuid
  contentType String   @map("content_type") @db.VarChar(50)
  body        String?
  mediaUrl    String?  @map("media_url") @db.VarChar(1000)
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @map("created_at") @db.Timestamptz(6)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_contents")
}

model CourseExercise {
  id             String   @id @default(uuid()) @db.Uuid
  lessonId       String   @map("lesson_id") @db.Uuid
  title          String   @db.VarChar(255)
  instructions   String?
  language       String   @db.VarChar(50)
  starterCode    String?  @map("starter_code")
  solutionCode   String?  @map("solution_code")
  expectedOutput String?  @map("expected_output")
  orderIndex     Int      @map("order_index")
  createdAt      DateTime @map("created_at") @db.Timestamptz(6)
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("course_exercises")
}

model CourseAsset {
  id        String   @id @default(uuid()) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  lessonId  String?  @map("lesson_id") @db.Uuid
  assetType String   @map("asset_type") @db.VarChar(50)
  fileName  String   @map("file_name") @db.VarChar(255)
  fileUrl   String   @map("file_url") @db.VarChar(1000)
  fileSize  Int?     @map("file_size")
  mimeType  String?  @map("mime_type") @db.VarChar(100)
  createdAt DateTime @map("created_at") @db.Timestamptz(6)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([courseId])
  @@index([lessonId])
  @@map("course_assets")
}

model Enrollment {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  courseId       String           @map("course_id") @db.Uuid
  status         String           @db.VarChar(20)
  enrolledAt     DateTime         @map("enrolled_at") @db.Timestamptz(6)
  completedAt    DateTime?        @map("completed_at") @db.Timestamptz(6)
  courseProgress CourseProgress?
  course         Course           @relation(fields: [courseId], references: [id])
  user           User             @relation(fields: [userId], references: [id])
  lessonProgress LessonProgress[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model LessonProgress {
  id           String     @id @default(uuid()) @db.Uuid
  enrollmentId String     @map("enrollment_id") @db.Uuid
  lessonId     String     @map("lesson_id") @db.Uuid
  isCompleted  Boolean    @map("is_completed")
  completedAt  DateTime?  @map("completed_at") @db.Timestamptz(6)
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  lesson       Lesson     @relation(fields: [lessonId], references: [id])

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
  @@map("lesson_progress")
}

model CourseProgress {
  id               String     @id @default(uuid()) @db.Uuid
  enrollmentId     String     @unique @map("enrollment_id") @db.Uuid
  totalLessons     Int        @map("total_lessons")
  completedLessons Int        @map("completed_lessons")
  progressPercent  Decimal    @map("progress_percent") @db.Decimal(5, 2)
  lastAccessedAt   DateTime?  @map("last_accessed_at") @db.Timestamptz(6)
  updatedAt        DateTime   @map("updated_at") @db.Timestamptz(6)
  enrollment       Enrollment @relation(fields: [enrollmentId], references: [id])

  @@map("course_progress")
}

model Certificate {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  courseId          String?       @map("course_id") @db.Uuid
  pathId            String?       @map("path_id") @db.Uuid
  certificateNumber String        @unique @map("certificate_number") @db.VarChar(100)
  type              String        @db.VarChar(20)
  issuedAt          DateTime      @map("issued_at") @db.Timestamptz(6)
  course            Course?       @relation(fields: [courseId], references: [id])
  learningPath      LearningPath? @relation(fields: [pathId], references: [id])
  user              User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("certificates")
}

model Quiz {
  id               String        @id @default(uuid()) @db.Uuid
  chapterId        String?       @map("chapter_id") @db.Uuid
  pathUnitId       String?       @map("path_unit_id") @db.Uuid
  title            String        @db.VarChar(255)
  passScore        Int           @map("pass_score")
  timeLimitSeconds Int?          @map("time_limit_seconds")
  createdAt        DateTime      @map("created_at") @db.Timestamptz(6)
  questions        Question[]
  attempts         QuizAttempt[]
  chapter          Chapter?      @relation(fields: [chapterId], references: [id])
  pathUnit         PathUnit?     @relation(fields: [pathUnitId], references: [id])

  @@index([chapterId])
  @@index([pathUnitId])
  @@map("quizzes")
}

model Question {
  id                 String              @id @default(uuid()) @db.Uuid
  quizId             String              @map("quiz_id") @db.Uuid
  body               String
  questionType       String              @map("question_type") @db.VarChar(50)
  orderIndex         Int                 @map("order_index")
  points             Int
  answerOptions      AnswerOption[]
  placementAnswers   PlacementAnswer[]
  quiz               Quiz                @relation(fields: [quizId], references: [id])
  quizAttemptAnswers QuizAttemptAnswer[]

  @@index([quizId])
  @@map("questions")
}

model AnswerOption {
  id                 String              @id @default(uuid()) @db.Uuid
  questionId         String              @map("question_id") @db.Uuid
  body               String
  isCorrect          Boolean             @map("is_correct")
  orderIndex         Int                 @map("order_index")
  question           Question            @relation(fields: [questionId], references: [id])
  placementAnswers   PlacementAnswer[]
  quizAttemptAnswers QuizAttemptAnswer[]

  @@index([questionId])
  @@map("answer_options")
}

model QuizAttempt {
  id               String              @id @default(uuid()) @db.Uuid
  userId           String              @map("user_id") @db.Uuid
  quizId           String              @map("quiz_id") @db.Uuid
  score            Int
  maxScore         Int                 @map("max_score")
  passed           Boolean
  timeTakenSeconds Int?                @map("time_taken_seconds")
  attemptedAt      DateTime            @map("attempted_at") @db.Timestamptz(6)
  answers          QuizAttemptAnswer[]
  quiz             Quiz                @relation(fields: [quizId], references: [id])
  user             User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([quizId])
  @@map("quiz_attempts")
}

model QuizAttemptAnswer {
  id               String        @id @default(uuid()) @db.Uuid
  attemptId        String        @map("attempt_id") @db.Uuid
  questionId       String        @map("question_id") @db.Uuid
  selectedOptionId String?       @map("selected_option_id") @db.Uuid
  isCorrect        Boolean       @map("is_correct")
  attempt          QuizAttempt   @relation(fields: [attemptId], references: [id])
  question         Question      @relation(fields: [questionId], references: [id])
  selectedOption   AnswerOption? @relation(fields: [selectedOptionId], references: [id])

  @@index([attemptId])
  @@map("quiz_attempt_answers")
}

model LearningPath {
  id                String               @id @default(uuid()) @db.Uuid
  title             String               @db.VarChar(255)
  slug              String               @unique @db.VarChar(300)
  description       String?
  level             String               @db.VarChar(20)
  language          String               @db.VarChar(10)
  status            String               @db.VarChar(20)
  estimatedDays     Int?                 @map("estimated_days")
  createdAt         DateTime             @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @map("updated_at") @db.Timestamptz(6)
  certificates      Certificate[]
  pathUnits         PathUnit[]
  placementAttempts PlacementAttempt[]
  userEnrollments   UserPathEnrollment[]

  @@map("learning_paths")
}

model PathUnit {
  id           String       @id @default(uuid()) @db.Uuid
  pathId       String       @map("path_id") @db.Uuid
  title        String       @db.VarChar(255)
  description  String?
  orderIndex   Int          @map("order_index")
  createdAt    DateTime     @map("created_at") @db.Timestamptz(6)
  pathLessons  PathLesson[]
  learningPath LearningPath @relation(fields: [pathId], references: [id])
  quizzes      Quiz[]

  @@index([pathId])
  @@map("path_units")
}

model PathLesson {
  id                   String                 @id @default(uuid()) @db.Uuid
  unitId               String                 @map("unit_id") @db.Uuid
  title                String                 @db.VarChar(255)
  orderIndex           Int                    @map("order_index")
  xpReward             Int                    @map("xp_reward")
  learningObjectiveIds Json?                  @map("learning_objective_ids")
  sourceCardIds        Json?                  @map("source_card_ids")
  createdAt            DateTime               @map("created_at") @db.Timestamptz(6)
  pathActivities       PathActivity[]
  pathUnit             PathUnit               @relation(fields: [unitId], references: [id])
  sourceCardLinks      PathLessonSourceCard[]
  userPathProgress     UserPathProgress[]

  @@index([unitId])
  @@map("path_lessons")
}

model PathActivity {
  id                   String                   @id @default(uuid()) @db.Uuid
  pathLessonId         String                   @map("path_lesson_id") @db.Uuid
  activityType         String                   @map("activity_type") @db.VarChar(50)
  prompt               String
  correctAnswer        String?                  @map("correct_answer")
  options              Json?
  orderIndex           Int                      @map("order_index")
  xpReward             Int                      @map("xp_reward")
  reviewStatus         String                   @default("pending_review") @map("review_status") @db.VarChar(20)
  qualityScore         Int?                     @map("quality_score")
  reviewedAt           DateTime?                @map("reviewed_at") @db.Timestamptz(6)
  reviewedBy           String?                  @map("reviewed_by") @db.VarChar(255)
  reviewNotes          String?                  @map("review_notes")
  generationCount      Int                      @default(1) @map("generation_count")
  generationRunId      String?                  @map("generation_run_id") @db.Uuid
  learningObjectiveIds Json?                    @map("learning_objective_ids")
  sourceCardIds        Json?                    @map("source_card_ids")
  activityValidations  ActivityValidation[]
  dailyPlanItems       DailyPlanItem[]
  generationRun        GenerationRun?           @relation("PathActivityGenerationRun", fields: [generationRunId], references: [id], onDelete: SetNull)
  pathLesson           PathLesson               @relation(fields: [pathLessonId], references: [id])
  reviewQueueItems     ReviewQueueItem[]
  sourceCardLinks      PathActivitySourceCard[]

  @@unique([pathLessonId, orderIndex])
  @@index([pathLessonId])
  @@index([reviewStatus])
  @@index([generationRunId])
  @@map("path_activities")
}

model OnboardingResponse {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  questionKey String   @map("question_key") @db.VarChar(100)
  answerValue String   @map("answer_value") @db.VarChar(255)
  respondedAt DateTime @map("responded_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("onboarding_responses")
}

model PlacementAttempt {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  pathId           String            @map("path_id") @db.Uuid
  score            Int?
  assignedLevel    String?           @map("assigned_level") @db.VarChar(20)
  attemptedAt      DateTime          @map("attempted_at") @db.Timestamptz(6)
  placementAnswers PlacementAnswer[]
  learningPath     LearningPath      @relation(fields: [pathId], references: [id])
  user             User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([pathId])
  @@map("placement_attempts")
}

model PlacementAnswer {
  id                 String           @id @default(uuid()) @db.Uuid
  placementAttemptId String           @map("placement_attempt_id") @db.Uuid
  questionId         String           @map("question_id") @db.Uuid
  selectedOptionId   String?          @map("selected_option_id") @db.Uuid
  isCorrect          Boolean          @map("is_correct")
  placementAttempt   PlacementAttempt @relation(fields: [placementAttemptId], references: [id])
  question           Question         @relation(fields: [questionId], references: [id])
  selectedOption     AnswerOption?    @relation(fields: [selectedOptionId], references: [id])

  @@index([placementAttemptId])
  @@map("placement_answers")
}

model UserPathEnrollment {
  id               String             @id @default(uuid()) @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  pathId           String             @map("path_id") @db.Uuid
  level            String             @db.VarChar(20)
  status           String             @db.VarChar(20)
  isActive         Boolean            @map("is_active")
  enrolledAt       DateTime           @map("enrolled_at") @db.Timestamptz(6)
  completedAt      DateTime?          @map("completed_at") @db.Timestamptz(6)
  dailyPlans       DailyPlan[]
  learningPath     LearningPath       @relation(fields: [pathId], references: [id])
  user             User               @relation(fields: [userId], references: [id])
  userPathProgress UserPathProgress[]

  @@unique([userId, pathId])
  @@index([userId])
  @@index([pathId])
  @@map("user_path_enrollments")
}

model UserPathProgress {
  id           String             @id @default(uuid()) @db.Uuid
  enrollmentId String             @map("enrollment_id") @db.Uuid
  pathLessonId String             @map("path_lesson_id") @db.Uuid
  isCompleted  Boolean            @map("is_completed")
  xpEarned     Int                @map("xp_earned")
  completedAt  DateTime?          @map("completed_at") @db.Timestamptz(6)
  enrollment   UserPathEnrollment @relation(fields: [enrollmentId], references: [id])
  pathLesson   PathLesson         @relation(fields: [pathLessonId], references: [id])

  @@unique([enrollmentId, pathLessonId])
  @@index([enrollmentId])
  @@map("user_path_progress")
}

model ReviewQueueItem {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @map("user_id") @db.Uuid
  pathActivityId   String          @map("path_activity_id") @db.Uuid
  intervalDays     Int             @map("interval_days")
  repetitionCount  Int             @map("repetition_count")
  easeFactor       Decimal         @map("ease_factor") @db.Decimal(4, 2)
  nextReviewDate   DateTime        @map("next_review_date") @db.Date
  lastReviewedDate DateTime?       @map("last_reviewed_date") @db.Date
  dailyPlanItems   DailyPlanItem[]
  pathActivity     PathActivity    @relation(fields: [pathActivityId], references: [id])
  user             User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([nextReviewDate])
  @@map("review_queue_items")
}

model DailyPlan {
  id           String             @id @default(uuid()) @db.Uuid
  userId       String             @map("user_id") @db.Uuid
  enrollmentId String             @map("enrollment_id") @db.Uuid
  planDate     DateTime           @map("plan_date") @db.Date
  isCompleted  Boolean            @map("is_completed")
  generatedAt  DateTime           @map("generated_at") @db.Timestamptz(6)
  items        DailyPlanItem[]
  enrollment   UserPathEnrollment @relation(fields: [enrollmentId], references: [id])
  user         User               @relation(fields: [userId], references: [id])

  @@unique([userId, planDate])
  @@index([userId])
  @@map("daily_plans")
}

model DailyPlanItem {
  id              String           @id @default(uuid()) @db.Uuid
  dailyPlanId     String           @map("daily_plan_id") @db.Uuid
  pathActivityId  String?          @map("path_activity_id") @db.Uuid
  reviewItemId    String?          @map("review_item_id") @db.Uuid
  itemType        String           @map("item_type") @db.VarChar(50)
  isCompleted     Boolean          @map("is_completed")
  orderIndex      Int              @map("order_index")
